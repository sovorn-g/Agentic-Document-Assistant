LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b-instruct-2507-q4_K_M
OLLAMA_BASE_URL=http://localhost:11434

# Docker/Compose only: set to 0 when building a hosted-provider image
# such as DeepSeek/OpenAI/Gemini that does not need Ollama installed.
INSTALL_OLLAMA=1
APP_PORT=7860

# For hosted OpenAI:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=sk-...

# For hosted Google Gemini:
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=...

# For hosted DeepSeek:
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-v4-flash
# DEEPSEEK_API_KEY=sk-...

# Langfuse Observability (optional)
# Set LANGFUSE_ENABLED=true and provide your API keys to enable tracing.
# Get your keys from https://cloud.langfuse.com or your self-hosted instance.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3000
